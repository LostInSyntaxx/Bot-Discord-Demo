{
  "name": "bot-discord-demo",
  "version": "1.0.0",
  "description": "Professional Discord.js v14 Bot with TypeScript and Bun",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "deploy": "bun run src/deploy.ts",
    "deploy:guild": "bun run src/deploy.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "bot",
    "discord.js",
    "typescript",
    "bun"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/ms": "^2.1.0",
    "discord.js": "^14.26.4",
    "ms": "^2.1.3",
    "shoukaku": "^4.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.14",
    "typescript": "^5.0.0"
  }
}
